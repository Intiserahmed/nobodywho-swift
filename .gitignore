# XCFramework - the root NobodyWhoFFI.xcframework IS committed for SPM
# Only ignore other xcframeworks and build artifacts
.build/**/*.xcframework/
DerivedData/**/*.xcframework/
*.xcframework.zip
# But don't ignore the bundled one:
!NobodyWhoFFI.xcframework/

